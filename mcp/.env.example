# Configuración del MCP Server para Glory
# Copia este archivo como .env y configura las variables

# URL de la API de Glory (WordPress REST API)
GLORY_API_URL=http://glorybuilder.local/wp-json/glory/v1

# Token de autenticación (Application Password de WordPress en Base64)
# Para generarlo:
# 1. Ve a WordPress Admin > Usuarios > Tu Perfil
# 2. Busca "Contraseñas de aplicación" (Application Passwords)
# 3. Genera una nueva contraseña
# 4. Codifica "usuario:contraseña" en Base64
# 5. Ejemplo: echo -n "admin:xxxx xxxx xxxx" | base64
GLORY_AUTH_TOKEN=tu_token_base64_aqui

# Modo debug (opcional)
DEBUG=false
