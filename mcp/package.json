{
    "name": "glory-mcp-server",
    "version": "1.0.0",
    "description": "Servidor MCP para gestión de tareas, proyectos y hábitos con Glory Tasks",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "glory-mcp-server": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "prepublishOnly": "npm run build",
        "start": "node dist/index.js",
        "dev": "tsx src/index.ts",
        "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "glory",
        "tareas",
        "tasks",
        "productividad",
        "ai",
        "claude",
        "antigravity"
    ],
    "author": "Glory Builder",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/nakomidev/glory-mcp-server"
    },
    "homepage": "https://task.nakomi.studio",
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "zod": "^3.22.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "tsx": "^4.0.0",
        "typescript": "^5.0.0"
    }
}
