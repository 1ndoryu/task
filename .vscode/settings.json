{
    "postman.settings.dotenv-detection-notification-visibility": false,
    "files.exclude": {
        "**/.history": true
    },
    "search.useIgnoreFiles": true,
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/vendor/**": true,
        "**/.history/**": true
    }
}
