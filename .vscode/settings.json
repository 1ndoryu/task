{
    // Configuración para varsense (CSS Variables Validator)
    "cssVarsValidator.enable": true,
    "cssVarsValidator.variableFiles": [
        "**/variables.css",
        "**/vars.css",
        "**/_variables.scss",
        "**/global.css",
        "**/styles.css"
    ],
    "cssVarsValidator.hardcodedDetection.enabled": true,
    "cssVarsValidator.hardcodedDetection.severity": "warning",
    "cssVarsValidator.hardcodedDetection.properties": {
        "color": true,
        "background-color": true
    },
    
    "postman.settings.dotenv-detection-notification-visibility": false,
    "files.exclude": {
        "**/.history": true
    },
    "search.useIgnoreFiles": true,
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/vendor/**": true,
        "**/.history/**": true
    },
    "intelephense.stubs": [
